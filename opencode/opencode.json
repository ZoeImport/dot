  "provider": {
    "tag-native": {
      "npm": "@ai-sdk/anthropic",
      "name": "Tag (ath)",
      "options": {
        "baseURL": "https://tag.airaphe.com",
        "apiKey": "TAG_API_KEY_PLACEHOLDER"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6 (ath)",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "xhigh": {
              "effort": "xhigh"
            },
            "max": {
              "effort": "max"
            }
          }
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7 (ath)",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "xhigh": {
              "effort": "xhigh"
            },
            "max": {
              "effort": "max"
            }
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (ath)",
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "xhigh": {
              "effort": "xhigh"
            },
            "max": {
              "effort": "max"
            }
          }
