{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "oh-my-openagent@latest",
    "/Users/zoe/ponytail/.opencode/plugins/ponytail.mjs"
  ],
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek Official",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "xxx"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (deepseek)",
          "limit": {
            "context": 1000000,
            "output": 384000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "max": {
              "effort": "max"
            }
          }
        }
      }
    },
    "unlimited": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.yygu.cn/v3/llm.chat",
        "apiKey": "xxx"
      },
      "models": {
        "aliyun/kimi-k2.6": {
          "name": "Kimi K2.6 (unlimited)",
          "limit": {
            "context": 262144,
            "output": 4096
          }
        },
        "deepseek/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (unlimited)",
          "limit": {
            "context": 1000000,
            "output": 384000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "max": {
              "effort": "max"
            }
          }
        }
      }
    }
  },
  "mcp": {
    "figma": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-mcp"
      ],
      "environment": {
        "FIGMA_API_KEY": "xxx"
      }
    },
    "pg-exambank": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://test_rw:d1f4G2_f_3b1d4b3e5@bj-postgres-41lsxpzg.sql.tencentcdb.com:29127/exambank_test?sslmode=disable&TimeZone=Asia/Shanghai"
      ]
    },
    "pg-daoxuequest": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://haojie:MwFAtiycL_2ehPkhY@bj-postgres-41lsxpzg.sql.tencentcdb.com:29127/daoxue_quest?sslmode=disable&TimeZone=Asia/Shanghai"
      ]
    },
    "mysql-dotpen": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@berthojoris/mcp-mysql-server",
        "mysql://dotpen_test_rw:u1jsdd6o518z16fs@bj-cdb-9qndmhm6.sql.tencentcdb.com:25201/dotpen_test",
        "list,read,utility"
      ]
    },
    "mysql-yygu": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@berthojoris/mcp-mysql-server",
        "mysql://yygu_test_rw:vhc99v3dcxico74h@bj-cdb-feu2hlj6.sql.tencentcdb.com:63807/yygu_test",
        "list,read,utility"
      ]
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "build": {
      "model": "unlimited/deepseek/deepseek-v4-flash",
      "fallback_models": [
        "deepseek/deepseek-v4-flash"
      ]
    },
    "oracle": {
      "model": "unlimited/deepseek/deepseek-v4-flash",
      "fallback_models": [
