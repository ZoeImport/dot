  "mcp": {
    "figma": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-mcp"
      ],
      "environment": {
        "FIGMA_API_KEY": "******"
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "build": {
      "fallback_models": [
        "unlimited/aliyun/glm-5.1",
        "unlimited/aliyun/kimi-k2.6",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6",
        "unlimited/aliyun/glm-5"
