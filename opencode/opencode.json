{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "oh-my-openagent@latest"
  ],
  "provider": {
    "tag-native": {
      "npm": "@ai-sdk/anthropic",
      "name": "Tag (ath)",
      "options": {
        "baseURL": "https://tag.airaphe.com",
        "apiKey": "xxx"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6 (ath)",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "xhigh": {
              "effort": "xhigh"
            },
            "max": {
              "effort": "max"
            }
          }
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7 (ath)",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "xhigh": {
              "effort": "xhigh"
            },
            "max": {
              "effort": "max"
            }
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (ath)",
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "xhigh": {
              "effort": "xhigh"
            },
            "max": {
              "effort": "max"
            }
          }
        },
        "gpt-5.5": {
          "name": "GPT-5.5 (ath)",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4 (ath)",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek Official",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "xxx"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (deepseek)",
          "limit": {
            "context": 1000000,
            "output": 384000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "max": {
              "effort": "max"
            }
          }
        }
      }
    },
    "unlimited": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.yygu.cn/v3/llm.chat",
        "apiKey": "xxx"
      },
      "models": {
        "aliyun/kimi-k2.6": {
          "name": "Kimi K2.6 (unlimited)",
          "limit": {
            "context": 262144,
            "output": 4096
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (unlimited)",
          "limit": {
            "context": 1000000,
            "output": 384000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "max": {
              "effort": "max"
            }
          }
        }
      }
    }
  },
    "mcp": {
    "figma": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-mcp"
      ],
      "environment": {
        "FIGMA_API_KEY": "******"
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "build": {
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "oracle": {
      "model": "unlimited/deepseek-v4-flash",
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "tag-native/claude-opus-4-7",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "deep": {
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "tag-native/claude-opus-4-7",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ],
      "model": "tag-native/gpt-5.4"
    },
    "ultrabrain": {
      "fallback_models": [
        "tag-native/claude-opus-4-7",
        "deepseek/deepseek-v4-flash",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "visual-engineering": {
      "fallback_models": [
        "tag-native/claude-opus-4-7",
        "deepseek/deepseek-v4-flash",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "quick": {
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "atlas": {
      "mode": "subagent",
      "description": "Plan Executor - executes implementation plans task by task",
      "model": "unlimited/deepseek-v4-flash",
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "tag-native/claude-opus-4-7",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "sisyphus": {
      "model": "unlimited/deepseek-v4-flash",
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "tag-native/claude-opus-4-7",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "sisyphus-junior": {
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "prometheus": {
      "color": "#FF5722",
      "mode": "primary",
      "description": "Plan agent for complex multi-step tasks. Consult Prometheus first before implementation. (Prometheus - OhMyOpenCode)",
      "model": "unlimited/deepseek-v4-flash",
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "tag-native/gpt-5.4",
        "tag-native/claude-opus-4-7",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "metis": {
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "momus": {
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "tag-native/gpt-5.4",
        "tag-native/claude-sonnet-4-6"
      ]
    },
    "multimodal-looker": {
      "fallback_models": [
        "tag-native/claude-sonnet-4-6",
        "deepseek/deepseek-v4-flash",
        "tag-native/gpt-5.4"
      ]
    }
  }
}
